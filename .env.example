# ---------------------------------------------------------------------------
# MongoDB connection (Mongoose)
# ---------------------------------------------------------------------------
# Option A (default): SRV connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority

# Option B (fallback if your network/DNS blocks SRV lookups):
# Standard connection string (no +srv). Resolve shard hosts + replicaSet via:
#   nslookup -type=SRV _mongodb._tcp.<cluster-host> 8.8.8.8
#   nslookup -type=TXT <cluster-host> 8.8.8.8
# MONGODB_URI=mongodb://<user>:<password>@cluster0-shard-00-00.<cluster-host>:27017,cluster0-shard-00-01.<cluster-host>:27017,cluster0-shard-00-02.<cluster-host>:27017/<database>?ssl=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Public (exposed to client, inlined at build time)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_APP_HOST=http://localhost:5000

# ---------------------------------------------------------------------------
# JWT secrets and expirations
# ---------------------------------------------------------------------------
JWT_TOKEN_SECRET=<random-secret>
JWT_TOKEN_EXPIRATION=900s
JWT_REFRESH_SECRET=<random-secret>
JWT_REFRESH_EXPIRATION=86400s
JWT_WS_SECRET=<random-secret>
JWT_WS_EXPIRATION=1800s

# ---------------------------------------------------------------------------
# Cookies
# ---------------------------------------------------------------------------
COOKIE_SECRET=<random-secret>
COOKIE_DOMAIN=.localhost
COOKIE_DOMAIN_PROD=.example.com

# ---------------------------------------------------------------------------
# Verification / lockout timings
# ---------------------------------------------------------------------------
HOURS_TO_VERIFY_EMAIL=4
HOURS_TO_VERIFY_RESET=1
MINUTES_TO_VERIFY_RESET=15
HOURS_TO_BLOCK=6
LOGIN_ATTEMPTS_TO_BLOCK=5

# ---------------------------------------------------------------------------
# SMTP (mailer)
# ---------------------------------------------------------------------------
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_USER=<smtp-user>
SMTP_AUTH_PASS=<smtp-password>
MAILER_DEFAULT_FROM="No Reply" <noreply@example.com>

# ---------------------------------------------------------------------------
# Email templates / links (links point to app pages, same origin)
# ---------------------------------------------------------------------------
EMAIL_VERIFY_SUBJECT=Email verification
EMAIL_VERIFY_TEMPLATE=verify-email.hbs
EMAIL_VERIFY_LINK=/verify-email
EMAIL_FORGOT_SUBJECT=Forgotten password
EMAIL_FORGOT_TEMPLATE=forgot-pass.hbs
EMAIL_FORGOT_LINK=/verify-forgot-pass

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=5000
